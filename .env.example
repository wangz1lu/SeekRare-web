# SeekRare Web 配置

# LLM API 配置
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=

# 可选：参考基因组和注释文件路径（请根据实际情况配置）
# REF_FASTA=/path/to/GRCh38.fa
# GTF_FILE=/path/to/genomic.gtf
# CLINVAR_VCF=/path/to/clinvar.vcf.gz
# DBSNP_VCF=/path/to/dbsnp.vcf.gz

# API 服务端口
PORT=8000
